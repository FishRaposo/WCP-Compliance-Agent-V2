# WCP Compliance Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED
# ============================================================================

# OpenAI API Key
# Set to 'mock', 'mock-key', 'test-api-key', or leave empty for mock mode (no API calls)
# Set to a real key starting with 'sk-' for live mode
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================

# OpenAI Model to use
# Default: gpt-5.4
OPENAI_MODEL=gpt-5.4

# Maximum steps for agent execution
# Default: 3
AGENT_MAX_STEPS=3

# Agent timeout in milliseconds
# Default: 30000
AGENT_TIMEOUT=30000

# OpenAI temperature (0.0-1.0)
# Default: 0.7
OPENAI_TEMPERATURE=0.7

# Maximum tokens for OpenAI responses
# Default: 2000
OPENAI_MAX_TOKENS=2000

# ============================================================================
# DATABASE CONFIGURATION (Future - Phase 2+)
# ============================================================================

# Database connection URL
# For local development: file:./data/local.db
# For production: postgresql://user:pass@localhost:5432/wcp
DATABASE_URL=file:./data/local.db

# Maximum database connections
# Default: 10
DB_MAX_CONNECTIONS=10

# Database migration path
# Default: ./migrations
DB_MIGRATION_PATH=./migrations

# Enable database query logging
# Default: false
DB_LOGGING=false

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Server port
# Default: 3000
PORT=3000

# Server host
# Default: localhost
HOST=localhost

# Allowed CORS origins (comma-separated)
# Default: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Enable CORS
# Default: true
ENABLE_CORS=true

# API timeout in milliseconds
# Default: 30000
API_TIMEOUT=30000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment: development, staging, production
# Default: development
NODE_ENV=development

# Log level: trace, debug, info, warn, error, fatal
# Default: info
LOG_LEVEL=info

# ============================================================================
# FEATURE FLAGS (Future - Phase 2+)
# ============================================================================

# Enable PDF parsing functionality
# Default: false
FEATURE_PDF_PARSING=false

# Enable RAG (Retrieval-Augmented Generation) lookup
# Default: false
FEATURE_RAG_LOOKUP=false

# Enable batch processing
# Default: false
FEATURE_BATCH_PROCESSING=false

# Enable observability features
# Default: true in production, false in development
FEATURE_OBSERVABILITY=false

# ============================================================================
# OBSERVABILITY (Future - Phase 2+)
# ============================================================================

# Enable observability
# Default: true in production, false in development
OBSERVABILITY_ENABLED=false

# Langfuse public key for AI tracing
# LANGFUSE_PUBLIC_KEY=your-langfuse-public-key

# Langfuse secret key
# LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# Langfuse host URL
# LANGFUSE_HOST=https://cloud.langfuse.com

# Enable AI tracing
# Default: true in production, false in development
AI_TRACING=false

# ============================================================================
# HYBRID RETRIEVAL (Future - Phase 2+)
# ============================================================================

# Elasticsearch URL for RAG
# ELASTICSEARCH_URL=http://localhost:9200

# Elasticsearch index name for WCP documents
# ELASTICSEARCH_INDEX=wcp-documents

# ============================================================================
# HUMAN REVIEW QUEUE (Future - Phase 2+)
# ============================================================================

# Human review queue persistence path
# HUMAN_REVIEW_QUEUE_PATH=./data/human-review-queue.json

# ============================================================================
# POSTGRES + PGVECTOR (Future - Phase 2+)
# ============================================================================

# PostgreSQL connection URL with pgvector support
# POSTGRES_URL=postgresql://user:pass@localhost:5432/wcp

# pgvector collection name
# PGVECTOR_COLLECTION=wcp_embeddings
