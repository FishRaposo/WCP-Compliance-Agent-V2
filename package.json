{
  "name": "wcp-ai-agent",
  "version": "0.1.0",
  "description": "Regulated-domain AI infrastructure case study for trustworthy LLM decision systems",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run clean --silent && tsc",
    "dev": "mastra dev",
    "start": "node dist/index.js",
    "serve": "node dist/server.js",
    "test": "npm run build && vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:pipeline": "vitest run tests/unit/pipeline-contracts.test.ts tests/unit/trust-score.test.ts tests/integration/decision-pipeline.test.ts",
    "test:calibration": "vitest run tests/eval/trust-calibration.test.ts --reporter=verbose",
    "test:coverage": "vitest run --coverage --exclude tests/eval",
    "lint:pipeline": "tsx scripts/lint-pipeline-discipline.ts"
  },
  "keywords": [
    "ai-infrastructure",
    "ai-agent",
    "wcp",
    "compliance",
    "evals",
    "guardrails"
  ],
  "author": "FishRaposo",
  "repository": {
    "type": "git",
    "url": "https://github.com/FishRaposo/WCP-Compliance-Agent.git"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^2.0.65",
    "@hono/node-server": "^1.19.7",
    "@mastra/core": "^0.24.0",
    "@mastra/libsql": "^0.16.4",
    "@mastra/loggers": "^0.10.19",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "hono": "^4.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "ts-morph": "^21.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "overrides": {
    "ai": "^4.3.19"
  }
}
